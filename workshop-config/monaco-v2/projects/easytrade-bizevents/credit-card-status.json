{
  "enabled": true,
  "ruleName": "{{ .name }}",
  "triggers": [
    {
      "source": { "dataSource": "request.method" },
      "type": "EQUALS",
      "value": "GET",
      "caseSensitive": false
    },
    {
      "source": { "dataSource": "request.path" },
      "type": "CONTAINS",
      "value": "/v1/orders/",
      "caseSensitive": false
    },
    {
      "source": { "dataSource": "request.path" },
      "type": "ENDS_WITH",
      "value": "/status",
      "caseSensitive": false
    }
  ],
  "event": {
    "provider": {
      "sourceType": "constant.string",
      "source": "www.easytrade.com"
    },
    "type": {
      "sourceType": "constant.string",
      "source": "com.easytrade.credit-card-status"
    },
    "category": {
      "sourceType": "request.path"
    },
    "data": []
  }
}
