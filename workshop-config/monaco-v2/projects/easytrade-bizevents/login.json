{
  "enabled": true,
  "ruleName": "{{ .name }}",
  "triggers": [
    {
      "source": { "dataSource": "request.method" },
      "type": "EQUALS",
      "value": "POST",
      "caseSensitive": false
    },
    {
      "source": { "dataSource": "request.path" },
      "type": "ENDS_WITH",
      "value": "/api/Login",
      "caseSensitive": false
    }
  ],
  "event": {
    "provider": {
      "sourceType": "constant.string",
      "source": "www.easytrade.com"
    },
    "type": {
      "sourceType": "constant.string",
      "source": "com.easytrade.login"
    },
    "category": {
      "sourceType": "request.path"
    },
    "data": [
      {
        "name": "username",
        "source": { "sourceType": "request.body", "path": "username" }
      }
    ]
  }
}
