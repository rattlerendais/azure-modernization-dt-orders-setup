{
  "name": "{{ .name }}",
  "rules": [
    {
      "enabled": true,
      "type": "ME",
      "attributeRule": {
        "entityType": "PROCESS_GROUP",
        "conditions": [
          {
            "key": "CLOUD_APPLICATION_NAMESPACE_NAME",
            "operator": "EQUALS",
            "stringValue": "easytrade",
            "caseSensitive": false
          }
        ],
        "pgToHostPropagation": true,
        "pgToServicePropagation": true
      }
    },
    {
      "enabled": true,
      "type": "ME",
      "attributeRule": {
        "entityType": "CLOUD_APPLICATION",
        "conditions": [
          {
            "key": "CLOUD_APPLICATION_NAMESPACE_NAME",
            "operator": "EQUALS",
            "stringValue": "easytrade",
            "caseSensitive": false
          }
        ]
      }
    },
    {
      "enabled": true,
      "type": "ME",
      "attributeRule": {
        "entityType": "WEB_APPLICATION",
        "conditions": [
          {
            "key": "WEB_APPLICATION_NAME",
            "operator": "CONTAINS",
            "stringValue": "easytrade",
            "caseSensitive": false
          }
        ]
      }
    },
    {
      "enabled": true,
      "type": "ME",
      "attributeRule": {
        "entityType": "CLOUD_APPLICATION_NAMESPACE",
        "conditions": [
          {
            "key": "CLOUD_APPLICATION_NAMESPACE_NAME",
            "operator": "EQUALS",
            "stringValue": "easytrade",
            "caseSensitive": true
          }
        ]
      }
    },
    {
      "enabled": true,
      "type": "ME",
      "attributeRule": {
        "entityType": "SERVICE",
        "serviceToHostPropagation": true,
        "serviceToPGPropagation": true,
        "conditions": [
          {
            "key": "SERVICE_TAGS",
            "operator": "EQUALS",
            "tag": {
              "context": "CONTEXTLESS",
              "key": "app",
              "value": "easytrade"
            }
          }
        ]
      }
    }
  ]
}
