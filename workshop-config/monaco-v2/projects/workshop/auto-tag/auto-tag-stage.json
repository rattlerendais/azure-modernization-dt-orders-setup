{
  "name": "{{ .name }}",
  "rules": [
    {
      "type": "ME",
      "enabled": true,
      "valueNormalization": "Leave text as-is",
      "valueFormat": "staging",
      "attributeRule": {
        "entityType": "PROCESS_GROUP",
        "pgToHostPropagation": true,
        "pgToServicePropagation": true,
        "conditions": [
          {
            "key": "PROCESS_GROUP_PREDEFINED_METADATA",
            "dynamicKey": "KUBERNETES_NAMESPACE",
            "operator": "EQUALS",
            "stringValue": "staging",
            "caseSensitive": false
          }
        ]
      }
    }
  ]
}
