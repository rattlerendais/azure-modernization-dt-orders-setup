{
  "name": "{{ .name }}",
  "rules": [
    {
      "type": "ME",
      "enabled": true,
      "valueNormalization": "Leave text as-is",
      "valueFormat": "staging",
      "attributeRule": {
        "entityType": "CLOUD_APPLICATION_NAMESPACE",
        "serviceToHostPropagation": false,
        "serviceToPGPropagation": true,
        "conditions": [
          {
            "key": "CLOUD_APPLICATION_NAMESPACE_NAME",
            "operator": "EQUALS",
            "stringValue": "staging",
            "caseSensitive": false
          }
        ]
      }
    }
  ]
}
